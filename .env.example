# ── Admin ──────────────────────────────────────────────────────
# Cambia estas credenciales antes de desplegar en producción
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-clave-segura

# ── Wompi (pasarela de pagos) ──────────────────────────────────
# Obtén tus claves en https://comercios.wompi.co → Desarrolladores
# Sandbox (pruebas): prefijo pub_test_ / prod_test_
# Producción:        prefijo pub_prod_ / prod_
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Servidor ───────────────────────────────────────────────────
# Railway/Render asignan PORT automáticamente — no lo cambies en producción
PORT=8080
